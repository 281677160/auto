#!/bin/sh

# AutoUpdate for Openwrt
# /usr/bin/AutoUpdate
LOG_FILE="/tmp/autoupdate.log"

# 函数：远程检测
Remote_detection() {
  rm -rf /tmp/*_version

  if ! grep -q "GITHUB_LINK" "/etc/openwrt_update" || ! grep -q "RELEASE_DOWNLOAD" "/etc/openwrt_update"; then
    echo "缺少openwrt_update文件" > /tmp/cloud_version
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 缺少openwrt_update文件"
    exit 1
  fi

  source /etc/openwrt_update

  if ! wget --timeout=40 -t 1 --no-check-certificate "${RELEASE_DOWNLOAD1}/zzz_api" -O /tmp/api_version; then
    curl -fsSL --max-time 40 -k "${RELEASE_DOWNLOAD2}/zzz_api" -o /tmp/api_version
  fi

  if ! grep -q "assets" /tmp/api_version; then
    echo "获取API数据失败,Github地址不正确或网络问题？" > /tmp/cloud_version
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取API数据失败,Github地址不正确或网络问题？"
    exit 1
  else
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取API数据成功！"
  fi
}

# 函数：远程信息获取
Remote_information() {
  source /etc/openwrt_update

  BOOT_TYPE=""
  if [ "${TARGET_BOARD}" = "x86" ]; then
    if [ -d '/sys/firmware/efi' ]; then
      BOOT_TYPE="uefi"
    else
      BOOT_TYPE="legacy"
    fi
  elif [ "${FIRMWARE_SUFFIX}" = ".img.gz" ]; then
    BOOT_TYPE="legacy"
  else
    BOOT_TYPE="sysupgrade"
  fi

  regex="https://.*${LUCI_EDITION}-${SOURCE}-${DEVICE_MODEL}-0-9]+-${BOOT_TYPE}-.*${FIRMWARE_SUFFIX}"
  target_line=$(grep -E "$regex" /tmp/api_version | tail -n 1)

  if [ -n "$target_line" ]; then
    REMOTE_FIRMWARE=$(echo "$target_line" | sed -n "s/.*\"${LUCI_EDITION}-${SOURCE}-${DEVICE_MODEL}--9]+-${BOOT_TYPE}-//p" | sed "s/\".*//")
    CLOUD_VERSION=$(echo "$REMOTE_FIRMWARE" | cut -d '-' -f 5)
    CLOUD_MD256=$(echo "$REMOTE_FIRMWARE" | cut -d '-' -f 7 | cut -d '.' -f 1)
    CLOUD_FIRMWARE_SIZE=$(grep -n "$REMOTE_FIRMWARE" /tmp/api_version | tail -1 | cut -d ':' -f 1 | xargs -I {} sed -n "{}p" /tmp/api_version | grep -Eo "0-9]+" | awk '{sum+=$1} END {print sum/1048576+1}')

    echo "固件全名称: $REMOTE_FIRMWARE"
    echo "固件时间戳: $CLOUD_VERSION"
    echo "固件MD5值: $CLOUD_MD256"
    echo "大小 (MB): $CLOUD_FIRMWARE_SIZE"
  else
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取固件信息失败"
    exit 1
  fi

  KERNEL_MODE=$(uname -rs | awk '{print $2}')
  TMP_AVAILABLE=$(df -m | grep "/tmp" | awk '{print $4}' | awk 'NR==1' | cut -d '.' -f 1)
  EQUIPMENT_NAME=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)
  LOCAL_VERSION=$(echo "${FIRMWARE_VERSION}" | awk -F'-' '{print $NF}')
  CLOUD_FIRMWARE_VERSION="${SOURCE}-${DEVICE_MODEL}-${CLOUD_VERSION}"

  if [ -z "${LOCAL_VERSION}" ]; then
    echo "未知原因,获取本地版本号失败!" > /tmp/cloud_version
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 未知原因,获取本地版本号失败!"
    exit 1
  else
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取本地版本号成功!"
  fi

  if [ -z "${CLOUD_VERSION}" ]; then
    echo "获取云端信息失败,请检查云端固件是否存在或网络问题！" > /tmp/cloud_version
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取云端信息失败,请检查云端固件是否存在或网络问题！"
    exit 1
  else
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 获取云端版本号成功!"
  fi

  if [ "$TMP_AVAILABLE" -lt "$CLOUD_FIRMWARE_SIZE" ]; then
    echo "固件tmp空间不足${TMP_AVAILABLE}M < ${CLOUD_FIRMWARE_SIZE}M]" > /tmp/cloud_version
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 固件tmp空间不足${TMP_AVAILABLE}M < ${CLOUD_FIRMWARE_SIZE}M]"
    exit 1
  else
    echo "$(date "+%Y年%m月%d日%H时%M分%S秒") 固件tmp空间足够${TMP_AVAILABLE}M >= ${CLOUD_FIRMWARE_SIZE}M]"
  fi

  cat > /tmp/tags_version <<-EOF
MODEL_TYPE=${BOOT_TYPE}${FIRMWARE_SUFFIX}
KERNEL_TYPE=${KERNEL_MODE} - ${LUCI_EDITION}
EQUIPMENT_NAME=${EQUIPMENT_NAME}
EOF

  if [ -n "${LOCAL_VERSION}" ] && [ -n "${CLOUD_VERSION}" ]; then
    if [ "$LOCAL_VERSION" -eq "$CLOUD_VERSION" ]; then
      echo "${CLOUD_FIRMWARE_VERSION} 已是最新]" > /tmp/cloud_version
      exit 0
    elif [ "$LOCAL_VERSION" -lt "$CLOUD_VERSION" ]; then
      echo "${CLOUD_FIRMWARE_VERSION} 有可更新固件]" > /tmp/cloud_version
      echo "update" > /tmp/compare_version
    elif [ "$LOCAL_VERSION" -gt "$CLOUD_VERSION" ]; then
      echo "${CLOUD_FIRMWARE_VERSION} 云端版本低于当前版本]" > /tmp/cloud_version
      exit 0
    fi
  fi
}

Remote_download() {
  # 初始化下载目录
  mkdir -p "${DOWNLOAD_PATH}" || { echo "创建目录失败"; exit 1; }
  cd "${DOWNLOAD_PATH}" || exit 1
  rm -rf ./*

  # 统一日期格式
  current_time=$(date "+%Y-%m-%d %H:%M:%S")
  
  # 网络检测优化
  check_network() {
    for site in "${RELEASE_DOWNLOAD1}" "${RELEASE_DOWNLOAD2}"; do
      if curl -Is --connect-timeout 5 "${site}" >/dev/null; then
        echo "${site}" && return 0
      fi
    done
    return 1
  }

  # 获取可用下载源
  if ! selected_site=$(check_network); then
    echo "[${current_time}] 网络连接失败" | tee -a "${LOG_FILE}"
    exit 1
  fi

  # 下载逻辑优化
  download_file() {
    for retry in 1 2 3; do
      if wget --timeout=600 --tries=1 --no-check-certificate \
        "${selected_site}/${REMOTE_FIRMWARE}" -O "${REMOTE_FIRMWARE}"; then
        return 0
      fi
      sleep 5
    done
    return 1
  }

  # 执行下载
  echo "[${current_time}] 开始下载: ${selected_site}/${REMOTE_FIRMWARE}" | tee -a "${LOG_FILE}"
  if ! download_file; then
    echo "[${current_time}] 下载失败" | tee -a "${LOG_FILE}"
    exit 1
  fi

  # 哈希校验增强
  verify_hash() {
    local_md5=$(md5sum "${REMOTE_FIRMWARE}" | awk '{print $1}')
    local_sha256=$(sha256sum "${REMOTE_FIRMWARE}" | awk '{print $1}')
    
    if [ "${CLOUD_MD256}" != "${local_md5}" ] || [ "${CLOUD_SHA256}" != "${local_sha256}" ]; then
      return 1
    fi
    return 0
  }

  if ! verify_hash; then
    echo "[${current_time}] 文件校验失败" | tee -a "${LOG_FILE}"
    exit 1
  fi

  # 备份流程优化
  create_backup() {
    backup_file="/mnt/upback_$(date +%Y%m%d).tar.gz"
    if sysupgrade -b "${backup_file}"; then
      echo "${backup_file}"
    else
      # 关键配置备份
      tar -czf "${backup_file}" /etc/config/ /etc/opkg/ 2>/dev/null
      [ $? -eq 0 ] && echo "${backup_file}"
    fi
  }

  # 执行备份
  echo "[${current_time}] 开始系统备份..." | tee -a "${LOG_FILE}"
  backup_file=$(create_backup)
  
  # 升级命令生成
  if [ -n "${backup_file}" ]; then
    UPGRADE_CMD="sysupgrade -n -f ${backup_file}"
  else
    UPGRADE_CMD="sysupgrade -n"
  fi

  # 执行升级
  echo "[${current_time}] 启动固件升级..." | tee -a "${LOG_FILE}"
  ${UPGRADE_CMD} "${REMOTE_FIRMWARE}"
}

# 命令行处理
case "$1" in
  "-u")  # 完整升级流程
    Remote_detection
    Remote_information
    Remote_download
    ;;
  "-k")  # 快速升级模式
    Remote_information
    Remote_download
    ;;
  *)    # 默认检测模式
    Remote_detection
    Remote_information
    ;;
esac

exit 0

