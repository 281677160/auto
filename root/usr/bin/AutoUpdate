#!/bin/sh
# https://github.com/Hyy2001X/AutoBuild-Actions
# AutoBuild Module by Hyy2001
# AutoUpdate for Openwrt
# /usr/bin/AutoUpdate

function Remote_detection() {
rm -rf /tmp/*_version

if [[ -f "/etc/openwrt_update" ]]; then
  source /etc/openwrt_update
else
  echo "缺少openwrt_update文件" > /tmp/cloud_version
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 缺少openwrt_update文件]"
  exit 1
fi

if ! wget --timeout=40 -t 1 "${RELEASE_DOWNLOAD1}/zzz_api" -O /tmp/api_version; then
  curl -fsSL --max-time 40 "${RELEASE_DOWNLOAD2}/zzz_api" -o /tmp/api_version
fi

if [[ -z "$(grep -E "assets" /tmp/api_version)" ]]; then
  echo "获取API数据失败,请检测网络,或您的github仓库为私库?" > /tmp/cloud_version
  exit 1
fi

if [[ -z "$(grep -E "assets" /tmp/api_data)" ]]; then
  echo "获取API数据失败,Github地址不正确?，或此地址没云端存在，或您的仓库为私库?" > /tmp/cloud_version
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取API数据成功!]"
fi
}

function Remote_information() {
source /etc/openwrt_update
if [[ "${TARGET_BOARD}" == "x86" ]]; then
  if [[ -d '/sys/firmware/efi' ]]; then
    BOOT_TYPE=uefi
  else
    BOOT_TYPE=legacy
  fi
elif [[ "${FIRMWARE_SUFFIX}" == ".img.gz" ]]; then
  BOOT_TYPE=legacy
else
  BOOT_TYPE=sysupgrade
fi

# 获取固件数据
regex="https://.*${LUCI_EDITION}-${SOURCE}-${DEVICE_MODEL}-[0-9]+-${BOOT_TYPE}-.*${FIRMWARE_SUFFIX}"
# 查找目标行
target_line=$(grep -E "$regex" /tmp/api_version | tail -n 1)
if [ -n "$target_line" ]; then
    # 从行中提取固件全名称
    start_str="${LUCI_EDITION}-${SOURCE}-${DEVICE_MODEL}-"
    REMOTE_FIRMWARE=$(echo "$target_line" | awk -v pattern="$regex" -v start="$start_str" -F'"' '{
        for(i=1; i<=NF; i++) {
            if($i ~ pattern) {
                print substr($i, index($i, start))
                break
            }
        }
    }')
    # 提取云端版本号
    CLOUD_VERSION=$(echo "$REMOTE_FIRMWARE" | awk -F'-' '{print $5}')
    # 提取云端已有的固件MD5值
    CLOUD__MD256=$(echo "$REMOTE_FIRMWARE" | awk -F'-' '{print $7}' | awk -F'.' '{print $1}')
    # 提取云端已有的固件size值
    let X=$(grep -n "$REMOTE_FIRMWARE" /tmp/api_version | tail -1 | cut -d : -f 1)-4
    let CLOUD_FIRMWARE_SIZE=$(sed -n "${X}p" /tmp/api_version | grep -Eo "[0-9]+" | awk '{print ($1)/1048576}' | awk -F. '{print $1}')+1
    echo "固件全名称: $REMOTE_FIRMWARE"
    echo "固件时间戳: $CLOUD_VERSION"
    echo "固件MD5值: $CLOUD__MD256"
    echo "大小 (MB): $CLOUD_FIRMWARE_SIZE"
else
    echo "获取固件信息失败"
    exit 1
fi

# 固件内核版本
KERNEL_MODE=$(uname -rs | cut -d ' ' -f2)
# 固件/tmp空间值
TMP_AVAILABLE=$(df -m | grep "/tmp" | awk '{print $4}' | awk 'NR==1' | awk -F. '{print $1}')
# 固件主机名称
EQUIPMENT_NAME=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)
# 本地版本号
LOCAL_VERSION=$(echo "${FIRMWARE_VERSION}" | awk -F'-' '{print $NF}')
# 云端版本显示名称
CLOUD_FIRMWARE_VERSION="${SOURCE}-${DEVICE_MODEL}-${CLOUD_VERSION}"

if [[ -z "${LOCAL_VERSION}" ]]; then
  echo "未知原因,获取本地版本号失败!" > /tmp/cloud_version
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取本地版本号成功!]"
fi
if [[ -z "${CLOUD_VERSION}" ]]; then
  echo "获取云端信息失败,x86注意本地跟云端固件显示的引导模式是否一致,或者就是云端压根就没您同类型的固件存在,或者作者更了固件获取条件导致您本地跟云端信息不一直!" > /tmp/cloud_version
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取云端版本号成功!]"
fi
if [[ "${TMP_AVAILABLE}" -lt "${CLOUD_FIRMWARE_SIZE}" ]]; then
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 固件tmp空间值[${TMP_AVAILABLE}M],云端固件体积[${CLOUD_FIRMWARE_SIZE}M],空间不足]"
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 固件tmp空间值[${TMP_AVAILABLE}M],云端固件体积[${CLOUD_FIRMWARE_SIZE}M]]"
fi

cat > /tmp/tags_version <<-EOF
MODEL_TYPE=${BOOT_TYPE}${FIRMWARE_SUFFIX}
KERNEL_TYPE=${KERNEL_MODE} - ${LUCI_EDITION}
EQUIPMENT_NAME=${EQUIPMENT_NAME}
EOF

if [[ -n "${LOCAL_VERSION}" ]] && [[ -n "${CLOUD_VERSION}" ]]; then
  if [[ "${LOCAL_VERSION}" -eq "${CLOUD_VERSION}" ]]; then
    echo "${CLOUD_FIRMWARE_VERSION} [已是最新]" > /tmp/cloud_version
    echo "no_update" > /tmp/compare_version
    exit 1
  elif [[ "${LOCAL_VERSION}" -lt "${CLOUD_VERSION}" ]]; then
    echo "${CLOUD_FIRMWARE_VERSION} [有可更新固件]" > /tmp/cloud_version
  elif [[ "${LOCAL_VERSION}" -gt "${CLOUD_VERSION}" ]]; then
    echo "${CLOUD_FIRMWARE_VERSION} [云端最高版本固件,低于您现在所使用版本,请到云端查看原因]" > /tmp/cloud_version
    echo "no_update" > /tmp/compare_version
    exit 1
  fi
fi
}

function Remote_download() {
[ ! -d "${DOWNLOAD_PATH}" ] && mkdir -p ${DOWNLOAD_PATH} || rm -rf $DOWNLOAD_PATH/*
cd "${DOWNLOAD_PATH}"
echo "${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE}"
echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 开始下载云端固件]"
if [[  "$(curl -I -s --connect-timeout 8 google.com -w %{http_code} | tail -n1)" == "301" ]]; then
  if ! wget -q --show-progress ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -O ${REMOTE_FIRMWARE}; then
    if ! curl -# -L ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}; then
      curl -# -L ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}
    fi
  fi
else
  if ! wget -q --show-progress ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -O ${REMOTE_FIRMWARE}; then
    if ! curl -# -L ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}; then
      curl -# -L ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}
    fi
  fi
fi

find . -maxdepth 1 -type f -size -2097152c -exec rm -f {} \;

if [[ ! -f "${REMOTE_FIRMWARE}" ]]; then
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 云端固件下载失败]"
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 云端固件下载成功]"
fi

LOCAL_MD5256=$(md5sum ${REMOTE_FIRMWARE} |cut -c1-3)$(sha256sum ${REMOTE_FIRMWARE} |cut -c1-3)
CLOUD__MD5256=${CLOUD__MD256}
if [[ ! "${CLOUD__MD5256}" == "${LOCAL_MD5256}" ]]; then
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") MD5对比失败,固件可能在下载时损坏,请检查网络后重试!]"
  exit 1
else
  echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") MD5对比成功]"
fi
exit 1

echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 正在执行更新固件前的备份]"
chmod 755 "${REMOTE_FIRMWARE}"
if [[ -n "$(opkg list | awk '{print $1}' | grep -E 'gzip')" ]]; then
  opkg remove gzip > /dev/null 2>&1
fi

if [[ -f "/etc/deletefile" ]]; then
  source /etc/deletefile
fi

rm -rf /etc/config/luci /tmp/luci
echo "*/5 * * * * sleep 240; sh /etc/networkdetection > /dev/null 2>&1" >> /etc/crontabs/root
/etc/init.d/cron restart
rm -rf /mnt/*upback.tar.gz && sysupgrade -b /mnt/upback.tar.gz
if [[ -n "$(ls -1 /mnt | grep -E 'upback.tar.gz')" ]]; then
  UPGRADE_COMMAND='sysupgrade -F -f /mnt/upback.tar.gz'
else
  UPGRADE_COMMAND='sysupgrade -F -q'
fi
echo "[$(date "+%Y年%m月%d日%H时%M分%S秒") 升级固件中，请勿断开路由器电源，END]"
${UPGRADE_COMMAND} ${REMOTE_FIRMWARE}
}

case "$1" in
  "-u")
    Remote_detection    
    Remote_information
    Remote_download
  ;;
  *)
    Remote_detection
    Remote_information
  ;;
esac
