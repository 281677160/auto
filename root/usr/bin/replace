#!/bin/sh
# https://github.com/Hyy2001X/AutoBuild-Actions
# AutoBuild Module by Hyy2001
# AutoUpdate for Openwrt
# /usr/bin/AutoUpdate
Green="\033[32m"
Red="\033[31m"
Yellow="\033[33m"
Blue="\033[36m"
Font="\033[0m"

function TIME() {
  case $1 in
    r) export Color="\e[31m";;
    g) export Color="\e[32m";;
    b) export Color="\e[34m";;
    y) export Color="\e[33m";;
    z) export Color="\e[35m";;
    l) export Color="\e[36m";;
  esac
echo
echo -e "\e[36m\e[0m${Color}${2}\e[0m"
}

function Remote_githuburl() {
clear
rm -rf /tmp/*_version

if [[ -f "/etc/openwrt_update" ]]; then
  source /etc/openwrt_update
else
  TIME r "[$(date "+%Y年%m月%d日%H时%M分%S秒") 缺少openwrt_update文件]"
  exit 1
fi

TIME y "是否更换仓库？需要更换请输入新仓库链接,不需要则留空回车即可."
TIME b "您现在仓库为：${GITHUB_LINK}"
read -p "请输入：" git_url
gith_url=${git_url:-"${GITHUB_LINK}"}
TIME g "您仓库链接为：${gith_url}"

TIME y "仓库链接是否正确？正确输入[Y/y]回车继续,重新输入则[Q/q]回车,[N/n]回车退出程序"
while :; do
read -p "请选择：" SNKC
  case ${SNKC} in
  [Yy])
      sed -i "s?${GITHUB_LINK}?${gith_url}?g" /etc/openwrt_update
      source /etc/openwrt_update
      break
  ;;
  [Qq])
      clear
      Remote_githuburl
      break
  ;;
  [Nn])
      exit 0
      break
  ;;
  *)
      TIME r "请输入正确选项"
  ;;
  esac
done
}

function Remote_detection() {
TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 正在获取API数据...]"
if ! wget -q --timeout=40 -t 1 "${RELEASE_DOWNLOAD1}/zzz_api" -O /tmp/api_version; then
  curl -# -L --max-time 40 "${RELEASE_DOWNLOAD2}/zzz_api" -o /tmp/api_version
fi

if [[ -z "$(grep -E "assets" /tmp/api_version)" ]]; then
  TIME r "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取API数据失败,Github地址不正确?，或此地址没云端存在，或您的仓库为私库?]"
  exit 1
else
  TIME g "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取API数据成功!]"
fi
}

function Remote_information() {
if [[ "${TARGET_BOARD}" == "x86" ]]; then
  if [[ -d '/sys/firmware/efi' ]]; then
    BOOT_TYPE=uefi
  else
    BOOT_TYPE=legacy
  fi
elif [[ "${FIRMWARE_SUFFIX}" == ".img.gz" ]]; then
  BOOT_TYPE=legacy
else
  BOOT_TYPE=sysupgrade
fi

TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 正在获取固件数据...]"
KERNEL_MODE=$(uname -rs | cut -d ' ' -f2)
LOCAL_VERSION=$(echo "${FIRMWARE_VERSION}" | awk -F'-' '{print $NF}')
REMOTE_FIRMWARE=$(grep -Eo "${LUCI_EDITION}-${SOURCE}-${DEVICE_MODEL}-[0-9]+-${BOOT_TYPE}-[a-zA-Z0-9]+${FIRMWARE_SUFFIX}" /tmp/api_version | awk 'END {print}')
CLOUD_VERSION=$(echo "${REMOTE_FIRMWARE}" |sed "s/.*${DEVICE_MODEL}//g" |sed "s/${BOOT_TYPE}.*//g" |grep -Eo [0-9]+)
y="${LUCI_EDITION}-${SOURCE}"
if [[ -n "${REMOTE_FIRMWARE}" ]]; then
  echo "${REMOTE_FIRMWARE}" > /tmp/FIRMWARE_BANBEN
else
  echo "" > /tmp/FIRMWARE_BANBEN
  sed -i '/^$/d' /tmp/FIRMWARE_BANBEN
fi
chmod +x /tmp/FIRMWARE_BANBEN

for x in "${R1}" "${R2}" "${R3}" "${R4}" "${R5}" "${R6}" "${R7}" "${R8}" "${R9}" "${R10}" "${R11}" "${R12}" "${R13}" "${R14}" "${R15}" "${R16}" "${R17}" "${R18}" "${R19}" "${R20}" \
"${R21}" "${R22}" "${R23}" "${R24}" "${R25}" "${R26}" "${R27}" "${R28}" "${R29}" "${R30}" "${R31}" "${R32}" "${R33}" "${R34}" "${R35}" "${R36}" "${R37}" "${R38}" "${R39}" "${R40}" \
"${R41}" "${R42}" "${R43}" "${R44}" "${R45}" "${R46}" "${R47}" "${R48}" "${R49}" "${R50}" "${R51}" "${R52}" "${R53}" "${R54}" "${R55}" "${R56}" "${R57}" "${R58}" "${R59}" "${R60}" \
"${R61}" "${R62}" "${R63}" "${R64}" "${R65}" "${R66}" "${R67}" "${R68}" "${R69}" "${R70}" "${R71}" "${R72}" "${R73}" "${R74}" "${R75}" "${R76}" "${R77}" "${R78}" "${R79}" "${R80}"; do
  Firmware_name="$({ grep -Eo "${x}-${DEVICE_MODEL}-[0-9]+-${BOOT_TYPE}-[a-zA-Z0-9]+${FIRMWARE_SUFFIX}" /tmp/api_version | awk 'END {print}';} 2>"/dev/null")"
  if [[ -n "${Firmware_name}" ]] && [[ ! "${x}" == "${y}" ]]; then
    echo "${Firmware_name}" >> /tmp/FIRMWARE_BANBEN
  fi
done

if [[ ! -s "/tmp/FIRMWARE_BANBEN" ]]; then
  TIME r "没有获取到任何数据"
  exit 1
else
  TIME g "[$(date "+%Y年%m月%d日%H时%M分%S秒") 获取固件数据成功!]"
fi

clear
echo
echo
echo
echo -e "${Green} 当前使用固件${Font}：${Blue}${FIRMWARE_VERSION}${Font}"
echo -e "${Green} 当前固件内核${Font}：${Blue}${KERNEL_MODE} - ${LUCI_EDITION}${Font}"
echo -e "${Green} 当前固件格式${Font}：${Blue}${BOOT_TYPE}${FIRMWARE_SUFFIX}${Font}"
echo -e "${Green} 当前设备型号${Font}：${Blue}${DEVICE_MODEL}${Font}"
echo
TIME y " 以下为可选升级固件："
TIME g " ******************************************************************" 
echo
cat /tmp/FIRMWARE_BANBEN |awk '$0=NR"、"$0'|awk '{print "  " $0}'
TIME g " ******************************************************************" 

if [[ -n "${CLOUD_VERSION}" ]]; then
  if [[ "${LOCAL_VERSION}" -eq "${CLOUD_VERSION}" ]]; then
    TIME b "提示：当前版本跟云端同类型固件版本是一致的"
  elif [[ "${LOCAL_VERSION}" -lt "${CLOUD_VERSION}" ]]; then
    TIME b "提示：云端同类型固件有更高版本固件,可进行更新操作"
  elif [[ "${LOCAL_VERSION}" -gt "${CLOUD_VERSION}" ]]; then
    TIME b "提示：不得了啊,兄弟,云端最高版本固件,低于您现在所安装的版本"
  fi
fi

XYZDSZ="$(cat /tmp/FIRMWARE_BANBEN |awk '$0=NR" "$0'| awk 'END {print}' |awk '{print $(1)}')"
TIME y "请输入您要安装的固件前面对应的数值(1~X)，输入[N/n]则为退出程序"
while :; do
  read -p "请输入您的选择：" YMXZ
  if [[ "${YMXZ}" =~ ^[Nn]$ ]]; then
      exit 0
  elif [[ -z "${YMXZ}" ]]; then
      TIME r "敬告,输入不能为空"
  elif [[ "$YMXZ" =~ ^[1-9]+$ ]]; then
    if [[ "${YMXZ}" -le "${XYZDSZ}" ]]; then
      REMOTE_FIRMWARE=$(cat /tmp/FIRMWARE_BANBEN | awk ''NR==${YMXZ}'')
      TIME g "您选择了安装 ${REMOTE_FIRMWARE} 固件"
      sleep 3
      break
    else
      TIME r "敬告,请输入正确数值(1~${XYZDSZ})" >&2
    fi
  else
      TIME r "敬告,请输入正确值"
  fi
done

if [[ -n "$(echo "${REMOTE_FIRMWARE}" |grep -E "${y}")" ]]; then
  echo
  TIME y "此固件跟您现在所用的固件为同类型固件"
  TIME g "可以选择保留配置或不保留配置升级"
  echo
  xuzqxz="输入[Y/y]为保留配置，输入[N/n]为不保留配置"
  while :; do
  read -p " ${xuzqxz}： " Bendi_Wsl
  case ${Bendi_Wsl} in
  [Yy])
    upgrade_tions="1"
    tongzhi="保留配置"
  break
  ;;
  [Nn])
    upgrade_tions="0"
    tongzhi="不保留配置"
  break
  ;;
  *)
    xuzqxz="请输入正确选[Y/n]"
  ;;
  esac
  done
else
   upgrade_tions="0"
   tongzhi="不保留配置"
fi
}

function Remote_upgrade() {
TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 检查设备空间]"
[ ! -d "${DOWNLOAD_PATH}" ] && mkdir -p ${DOWNLOAD_PATH} || rm -rf $DOWNLOAD_PATH/*
TMP_AVAILABLE=$(df -m | grep "/tmp" | awk '{print $4}' | awk 'NR==1' | awk -F. '{print $1}')
let X=$(grep -n "${REMOTE_FIRMWARE}" /tmp/api_version | tail -1 | cut -d : -f 1)-4
let CLOUD_FIRMWARE_SIZE=$(sed -n "${X}p" /tmp/api_version | grep -Eo "[0-9]+" | awk '{print ($1)/1048576}' | awk -F. '{print $1}')+1
if [[ "${TMP_AVAILABLE}" -lt "${CLOUD_FIRMWARE_SIZE}" ]]; then
  TIME r "[$(date "+%Y年%m月%d日%H时%M分%S秒") 设备tmp空间值[${TMP_AVAILABLE}M],云端固件体积[${CLOUD_FIRMWARE_SIZE}M],空间不足]"
  exit 1
else
  TIME g "[$(date "+%Y年%m月%d日%H时%M分%S秒") 设备tmp空间值[${TMP_Available}M],云端固件体积[${CLOUD_Firmware_Size}M],可下载固件升级]"
fi

cd "${DOWNLOAD_PATH}"
TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 开始下载云端固件...]"
if [[  "$(curl -I -s --connect-timeout 8 google.com -w %{http_code} | tail -n1)" == "301" ]]; then
  if ! wget -q --show-progress ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -O ${REMOTE_FIRMWARE}; then
    if ! curl -# -L ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}; then
      curl -# -L ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}
    fi
  fi
else
  if ! wget -q --show-progress ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -O ${REMOTE_FIRMWARE}; then
    if ! curl -# -L ${RELEASE_DOWNLOAD1}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}; then
      curl -# -L ${RELEASE_DOWNLOAD2}/${REMOTE_FIRMWARE} -o ${REMOTE_FIRMWARE}
    fi
  fi
fi

find . -maxdepth 1 -type f -size -2097152c -exec rm -f {} \;

if [[ ! -f "${REMOTE_FIRMWARE}" ]]; then
  TIME r "[$(date "+%Y年%m月%d日%H时%M分%S秒") 云端固件下载失败]"
  exit 1
else
  TIME g "[$(date "+%Y年%m月%d日%H时%M分%S秒") 云端固件下载成功]"
fi

TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 对比固件MD5值]"
LOCAL_MD5256=$(md5sum ${REMOTE_FIRMWARE} |cut -c1-3)$(sha256sum ${REMOTE_FIRMWARE} |cut -c1-3)
CLOUD__MD5256=$(echo "${REMOTE_FIRMWARE}" |sed "s/.*${BOOT_TYPE}//g" | sed -r "s/-(.*)${FIRMWARE_SUFFIX}/\1/")
if [[ ! "${CLOUD__MD5256}" == "${LOCAL_MD5256}" ]]; then
  TIME r "[$(date "+%Y年%m月%d日%H时%M分%S秒") MD5对比失败,固件可能在下载时损坏,请检查网络后重试!]"
  exit 1
else
  TIME g "[$(date "+%Y年%m月%d日%H时%M分%S秒") MD5对比成功]"
fi

chmod 755 "${REMOTE_FIRMWARE}"
if [[ -n "$(opkg list | awk '{print $1}' | grep -E 'gzip')" ]]; then
  opkg remove gzip > /dev/null 2>&1
fi

if [[ "${upgrade_tions}" == "1" ]]; then
  TIME y "[$(date "+%Y年%m月%d日%H时%M分%S秒") 正在执行更新固件前的备份]"
  if [[ -f "/etc/deletefile" ]]; then
    source /etc/deletefile
  fi

  mv /etc/config/luci /tmp/luciaaa
  echo "*/5 * * * * sleep 240; sh /etc/networkdetection > /dev/null 2>&1" >> /etc/crontabs/root
  /etc/init.d/cron restart
  rm -rf /mnt/*upback.tar.gz && sysupgrade -b /mnt/upback.tar.gz
  mv /tmp/luciaaa /etc/config/luci
  if [[ -n "$(ls -1 /mnt | grep -E 'upback.tar.gz')" ]]; then
    UPGRADE_COMMAND='sysupgrade -F -f /mnt/upback.tar.gz'
  else
    UPGRADE_COMMAND='sysupgrade -F -q'
  fi
else
  UPGRADE_COMMAND='sysupgrade -F -n'  
fi

TIME g "[倒计10秒后,执行[${tongzhi}]更新,更新期间请不要断开电源或重启设备 ...]"
sleep 1
seconds=9
while [ $seconds -gt 0 ];do
  echo -n " ${seconds}"
  sleep 1
  seconds=$((${seconds} - 1))
  echo -ne "\r   \r"
done

${UPGRADE_COMMAND} ${REMOTE_FIRMWARE}
}

case "$1" in
  "-u")
    Remote_githuburl
    Remote_detection
    Remote_information
    Remote_upgrade
  ;;
  *)
    Remote_githuburl
    Remote_detection
    Remote_information
  ;;
esac
